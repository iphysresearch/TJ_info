{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Taiji Publications Database Schema",
  "description": "JSON Schema for validating the Taiji publications database",
  "type": "object",
  "required": ["metadata", "entries"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "project", "last_updated"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$",
          "description": "Database schema version"
        },
        "project": {
          "type": "string",
          "description": "Project name"
        },
        "created_date": {
          "type": "string",
          "format": "date",
          "description": "Database creation date"
        },
        "last_updated": {
          "type": "string",
          "format": "date",
          "description": "Last modification date"
        },
        "total_entries": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of entries"
        },
        "description": {
          "type": "string",
          "description": "Database description"
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/entry"
      }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["entry_id", "title", "authors", "year"],
      "properties": {
        "entry_id": {
          "type": "string",
          "description": "Unique identifier (DOI preferred, or arxiv:XXXX.XXXXX)"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Publication title"
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/author"
          },
          "description": "List of authors"
        },
        "year": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2100,
          "description": "Publication year"
        },
        "journal": {
          "type": "string",
          "description": "Journal name"
        },
        "volume": {
          "type": "string",
          "description": "Journal volume"
        },
        "pages": {
          "type": "string",
          "description": "Page numbers or article ID"
        },
        "doi": {
          "type": "string",
          "pattern": "^10\\..+/.+$",
          "description": "Digital Object Identifier"
        },
        "arxiv_id": {
          "type": "string",
          "pattern": "^\\d{4}\\.\\d{4,5}(v\\d+)?$",
          "description": "arXiv identifier (e.g., 2401.12345)"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the publication"
        },
        "abstract": {
          "type": "string",
          "description": "Publication abstract"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keywords/tags"
        },
        "publication_type": {
          "type": "string",
          "enum": ["journal", "conference", "preprint", "thesis", "report"],
          "description": "Type of publication"
        },
        "featured": {
          "type": "boolean",
          "default": false,
          "description": "Whether this is a featured publication"
        },
        "classification": {
          "$ref": "#/definitions/classification"
        },
        "citations": {
          "$ref": "#/definitions/citations"
        },
        "metadata": {
          "$ref": "#/definitions/entry_metadata"
        }
      }
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Author name"
        },
        "affiliation": {
          "type": "string",
          "description": "Author affiliation"
        },
        "orcid": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$",
          "description": "ORCID identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address"
        }
      }
    },
    "classification": {
      "type": "object",
      "properties": {
        "research_area": {
          "type": "string",
          "enum": ["mission_design", "instrument", "data_analysis", "source_modeling", "science_case", "pathfinder"],
          "description": "Primary research area"
        },
        "source_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["mbhb", "emri", "galactic_binary", "sgwb", "verification_binary", "cosmological"]
          },
          "description": "Gravitational wave source types"
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["data_analysis", "waveform_modeling", "parameter_estimation", "noise_modeling", "tdi", "simulation"]
          },
          "description": "Analysis methods used"
        },
        "relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Taiji relevance score (0-1)"
        }
      }
    },
    "citations": {
      "type": "object",
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Citation count"
        },
        "last_updated": {
          "type": "string",
          "format": "date",
          "description": "Last citation count update date"
        },
        "source": {
          "type": "string",
          "enum": ["semantic_scholar", "crossref", "inspire", "ads", "manual"],
          "description": "Citation data source"
        },
        "citing_papers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of citing paper IDs"
        }
      }
    },
    "entry_metadata": {
      "type": "object",
      "properties": {
        "added_date": {
          "type": "string",
          "format": "date",
          "description": "Date entry was added"
        },
        "last_updated": {
          "type": "string",
          "format": "date",
          "description": "Last modification date"
        },
        "data_sources": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["arxiv", "crossref", "semantic_scholar", "inspire", "ads", "manual"]
          },
          "description": "Data sources used"
        },
        "quality_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Data quality score (0-1)"
        },
        "review_status": {
          "type": "string",
          "enum": ["pending", "reviewed", "verified"],
          "description": "Review status"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes"
        }
      }
    }
  }
}
